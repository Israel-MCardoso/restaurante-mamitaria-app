{
  "name": "restaurante-desktop-app",
  "version": "1.1.0",
  "private": true,
  "description": "Desktop operacional para escuta e impressão térmica de pedidos.",
  "main": "electron-bootstrap.js",
  "author": "OpenAI Codex",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "dist": "npm run build && electron-builder --win nsis",
    "start": "electron ."
  },
  "build": {
    "appId": "com.restaurante.desktop",
    "productName": "Restaurante Desktop",
    "icon": "build/icon.ico",
    "afterPack": "scripts/after-pack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/**/*",
      "config/**/*",
      "electron-bootstrap.js",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "dotenv": "^16.4.7",
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.5",
    "escpos-usb": "^3.0.0-alpha.4",
    "qz-tray": "^2.2.6"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^7.1.12",
    "wait-on": "^8.0.3"
  },
  "overrides": {
    "request": {
      "form-data": "2.5.4",
      "qs": "6.14.1",
      "tough-cookie": "4.1.3"
    }
  }
}
